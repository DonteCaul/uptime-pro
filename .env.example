# Copy this to .env and fill in values before running docker compose up

# PostgreSQL password (used by both postgres and backend services)
POSTGRES_PASSWORD=changeme

# Long random string for signing JWTs — generate with: openssl rand -hex 32
JWT_SECRET=change-this-to-a-long-random-string

# Google Places API key (optional — used for nearby dropzone lookup)
GOOGLE_PLACES_KEY=

# Dekunu device compat layer — set to true to accept syncs from Dekunu hardware
DEKUNU_COMPAT=false

# Host port the app is served on (default 80)
PORT=80
